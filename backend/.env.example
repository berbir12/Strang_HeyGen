# Required for video generation
OPENAI_API_KEY=
HEYGEN_API_KEY=

# --- Auth (Supabase) ---
# Get these from your Supabase project → Settings → API
# JWT secret is under Settings → API → JWT Secret
SUPABASE_JWT_SECRET=

# --- Payments (Stripe) ---
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Create a product + price in Stripe Dashboard, paste the price ID here
STRIPE_PRICE_ID=

# Landing page URL (for Stripe redirect after checkout)
LANDING_PAGE_URL=http://localhost:5173

# --- Legacy auth (optional, for admin/testing) ---
# STRANG_API_KEY=

# Optional: CORS origins (comma-separated). Default "*" allows all.
# In production, lock down to your extension + landing page:
# CORS_ORIGINS=chrome-extension://abcdef1234,https://strang.ai

# Optional: rate limit (requests per window)
# RATE_LIMIT_REQUESTS=10
# RATE_LIMIT_WINDOW_SEC=3600

# Optional: free tier video limit (default 3)
# FREE_TIER_VIDEO_LIMIT=3

# Optional: directory for strang.db (default: same dir as main.py)
# DATA_DIR=./data

# Optional: override the OpenAI model (default: gpt-4.1)
# OPENAI_MODEL=gpt-4.1-mini
