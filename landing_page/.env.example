# Backend API URL for waitlist and video generation.
# - Local dev: http://localhost:8000 (backend must be running)
# - Production: your deployed backend URL (e.g. https://strang-api.up.railway.app)
VITE_STRANG_API_URL=

# Supabase auth (get from Supabase Dashboard → Settings → API)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: Plausible analytics domain (e.g. strang.ai)
# VITE_PLAUSIBLE_DOMAIN=
